{
  "name": "midforge",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@midforge/web",
    "dev:server": "turbo run dev --filter=@midforge/game-server",
    "build": "turbo run build",
    "db:generate": "turbo run db:generate --filter=@midforge/db",
    "db:migrate": "turbo run db:migrate --filter=@midforge/db",
    "db:push": "turbo run db:push --filter=@midforge/db"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.0"
}
